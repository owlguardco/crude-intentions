# CRUDE INTENTIONS — environment variable template
#
# Copy to .env.local for development. In production, set these in
# Vercel Project Settings → Environment Variables.
#
# This file documents the env vars referenced by the codebase. Values
# below are placeholders — never commit real secrets.

# ─── Auth + secrets ──────────────────────────────────────────────────────
INTERNAL_API_KEY=
NEXT_PUBLIC_INTERNAL_API_KEY=
CRON_SECRET=
WEBHOOK_SECRET=

# ─── External APIs ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
EIA_API_KEY=
FRED_API_KEY=

# ─── KV / Redis ──────────────────────────────────────────────────────────
KV_REDIS_URL=

# ─── Vercel ──────────────────────────────────────────────────────────────
VERCEL_APP_URL=

# ─── Discord notifications ───────────────────────────────────────────────
# Discord channel webhook URL used by /api/cron/journal-reminder.
# When the daily 7 PM ET cron fires and finds no journal entry for the
# current UTC date, it POSTs a reminder to this URL.
DISCORD_JOURNAL_WEBHOOK_URL=
